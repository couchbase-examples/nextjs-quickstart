{
  "name": "nextjs-quickstart",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:default": "env-cmd -f .env.default next dev",
    "build": "npm run strip-cb-sdk && next build && npm run load-sample-data:no-env && npm run build-indexes:no-env",
    "start": "next start",
    "lint": "next lint",
    "format:check": "prettier --check ./**/*.js",
    "format:write": "prettier --write ./**/*.js",
    "check": "npm run format:check && npm run lint",
    "init-db:default": "env-cmd -f .env.default node ./util/initializeCbServer.js",
    "init-db:local": "env-cmd -f .env.local node ./util/initializeCbServer.js",
    "build-indexes": "env-cmd -f .env.local node ./util/buildIndexes.js",
    "build-indexes:no-env": "node ./util/buildIndexes.js",
    "load-sample-data": "env-cmd -f .env.local node ./util/loadSampleData.js",
    "load-sample-data:no-env": "node ./util/loadSampleData.js",
    "strip-cb-sdk": "sh -c 'target=$(find ./node_modules/couchbase -name couchbase_impl.node -print -quit); if [ -n \"$target\" ]; then strip --strip-debug \"$target\"; else echo \"No couchbase_impl.node found; skipping strip\"; fi'",
    "test": "env-cmd -f .env.default jest"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.19",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "couchbase": "^4.7.0",
    "next": "^13.5.11",
    "qs": "^6.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "eslint-config-prettier": "^8.10.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-test-api-route-handler": "^3.2.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19"
  },
  "license": "MIT"
}
